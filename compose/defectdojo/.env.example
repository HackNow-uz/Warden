# DefectDojo sozlamalari (compose/defectdojo/.env). MAJBURIY o'zgaruvchilar belgilanmasa
# `docker compose up` ataylab xato beradi (xavfsizlik — default maxfiy kalit yo'q).
DJANGO_VERSION=latest
NGINX_VERSION=latest

# Tashqi port (UI) va ruxsat etilgan hostlar
DD_PORT=8080
DD_TLS_PORT=8443
DD_ALLOWED_HOSTS=localhost,127.0.0.1   # prod'da o'z FQDN'ingizni qo'shing

# Admin (initializer yaratadi)
DD_ADMIN_USER=admin
DD_ADMIN_MAIL=admin@defectdojo.local
DD_ADMIN_FIRST_NAME=Admin
DD_ADMIN_LAST_NAME=User

# ===== MAJBURIY MAXFIY KALITLAR — har deploy uchun yangisini generatsiya qiling =====
#   DD_SECRET_KEY:             python -c 'import secrets; print(secrets.token_urlsafe(50))'
#   DD_CREDENTIAL_AES_256_KEY: openssl rand -base64 24
#   (AES kalitini rotatsiya qilsangiz, saqlangan kredensiallar o'qib bo'lmaydigan bo'ladi)
DD_SECRET_KEY=
DD_CREDENTIAL_AES_256_KEY=

# ===== MAJBURIY DB =====
#   DD_DATABASE_PASSWORD: openssl rand -base64 24
#   DD_DATABASE_URL parolni o'z ichiga oladi va yuqoridagi parolga MOS bo'lishi shart
DD_DATABASE_USER=defectdojo
DD_DATABASE_NAME=defectdojo
DD_DATABASE_PASSWORD=
DD_DATABASE_URL=postgresql://defectdojo:CHANGE_ME_DB_PASSWORD@postgres:5432/defectdojo
