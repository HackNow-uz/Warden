# DefectDojo sozlamalari (compose/defectdojo/.env). Prod'da MAJBURIY o'zgartiring!
DJANGO_VERSION=latest
NGINX_VERSION=latest

# Tashqi port (UI)
DD_PORT=8080
DD_TLS_PORT=8443

# Admin (initializer yaratadi). Parolni initializer log'i ko'rsatadi yoki bu yerda belgilang.
DD_ADMIN_USER=admin
DD_ADMIN_FIRST_NAME=Admin
DD_ADMIN_LAST_NAME=User

# MAXFIY — prod'da albatta yangisini generatsiya qiling:
#   DD_SECRET_KEY:            openssl rand -base64 48
#   DD_CREDENTIAL_AES_256_KEY: openssl rand -base64 24
DD_SECRET_KEY=CHANGE_ME_secret
DD_CREDENTIAL_AES_256_KEY=CHANGE_ME_aes

# DB / Redis (default qiymatlar compose ichida; prod'da kuchaytiring)
DD_DATABASE_PASSWORD=defectdojo
